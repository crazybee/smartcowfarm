{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker: up debug stack",
      "type": "shell",
      "command": "docker compose -f docker-compose.debug.yml up --build -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "docker: down debug stack",
      "type": "shell",
      "command": "docker compose -f docker-compose.debug.yml down -v",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
